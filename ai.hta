<html>
<head>
  <title>AI Launcher</title>
  <HTA:APPLICATION 
    APPLICATIONNAME="AI"
    BORDER="none"
    SHOWINTASKBAR="no"
  />
</head>

<script>
  var shell = new ActiveXObject("WScript.Shell");

  var command = 'powershell -NoExit -Command "Write-Host \\"Hi I am AI\\""';
  shell.Run(command);

  window.close();
</script>

<body></body>
</html>
